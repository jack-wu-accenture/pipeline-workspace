    },
    {
      "id": "K-boS0dzY1uFbPgNQpL6V",
      "type": "text",
      "x": 562.9418023352969,
      "y": 8823.159091449514,
      "width": 784,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
