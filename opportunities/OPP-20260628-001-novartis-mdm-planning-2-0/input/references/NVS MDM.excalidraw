      "boundElements": [],
      "updated": 1774922015246,
      "link": null,
      "locked": false,
      "text": "Submission Validation:\n1. LOV Validation\n2. Biz rules validation : \n     valid customer ID\n     winner loser cannot be same\n     ** validate DCR status（ user may submit appeal request when original DCR is still pending review）\n         1. if to reject and user appealed, show error\n         2. if to approve and user appealed, process approving dcr\n         3. if undetermined and user appealed, show error\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Submission Validation:\n1. LOV Validation\n2. Biz rules validation : \n     valid customer ID\n     winner loser cannot be same\n     ** validate DCR status（ user may submit appeal request when original DCR is still pending review）\n         1. if to reject and user appealed, show error\n         2. if to approve and user appealed, process approving dcr\n         3. if undetermined and user appealed, show error\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
