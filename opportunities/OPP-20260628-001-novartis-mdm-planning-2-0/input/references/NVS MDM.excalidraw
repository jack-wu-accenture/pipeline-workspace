      "type": "text",
      "x": 939.0878392994734,
      "y": 3108.982746427029,
      "width": 371.59449598524327,
      "height": 336.23456790123447,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
